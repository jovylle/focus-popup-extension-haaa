{
  "manifest_version": 3,
  "name": "Focus Popup",
  "version": "2.0.0",
  "description": "Open Messenger in a right-docked popup; toggle via toolbar or shortcut.",
  "permissions": ["windows", "system.display", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Focus Popup",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-messenger": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "Alt+Shift+M"
      },
      "description": "Toggle Messenger popup"
    }
  }
}
