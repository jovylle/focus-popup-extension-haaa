{
  "manifest_version": 3,
  "name": "Focus Popup",
  "version": "2.1.0",
  "description": "Dock Messenger as a pinned tab group—no extra window, no reload on toggle.",
  "permissions": ["tabs", "tabGroups", "storage"],
  "host_permissions": ["https://messenger.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Messenger"
  },
  "commands": {
    "toggle-messenger": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "Alt+Shift+M"
      },
      "description": "Toggle Messenger panel"
    }
  }
}
